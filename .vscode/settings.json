{
    "editor.tabSize": 2,
    "files.associations": {
        "array": "cpp",
        "vector": "cpp",
        "ostream": "cpp"
    },
    "C_Cpp.default.cppStandard": "c++23",
    "C_Cpp.default.includePath": [
        "/usr/include/python3.14",
        "${userHome}/.local/include",
        "${workspaceFolder}"
    ],
    "cmake.environment": {
        "LD_LIBRARY_PATH": "${userHome}/.local/lib64:${userHome}/.local/lib"
    },
    "cmake.configureArgs": [
        "-DFUHAN_BUILD_TESTING=ON"
    ],
    "cmake.configureEnvironment": {
        "VIRTUAL_ENV": "${workspaceFolder}/.venv"
    }
}